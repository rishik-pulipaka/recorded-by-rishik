# ─────────────────────────────────────────────────────────────────────────────
# Backend (FastAPI — set these in Render dashboard for production)
# ─────────────────────────────────────────────────────────────────────────────

# Neon Postgres — get from https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql+psycopg2://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Clerk — same secret key as frontend
CLERK_SECRET_KEY=sk_test_...

# Clerk JWKS URL — from https://dashboard.clerk.com → your app → API Keys → Advanced
# Format: https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-domain.clerk.accounts.dev/.well-known/jwks.json

# Resend — https://resend.com → API Keys (free: 3,000 emails/month)
RESEND_API_KEY=re_...

# Google Calendar OAuth — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry — https://sentry.io → your project → Settings → Client Keys
SENTRY_DSN=

# Runtime environment
ENVIRONMENT=development

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","https://your-vercel-app.vercel.app"]

# Public base URL of THIS API (used for Google OAuth callback)
API_BASE_URL=http://localhost:8000
