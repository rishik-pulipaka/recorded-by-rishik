# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Next.js — set these in Vercel dashboard for production)
# ─────────────────────────────────────────────────────────────────────────────

# Clerk — get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (adjust if your domain differs)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# FastAPI backend URL (Render URL once deployed, localhost for local dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Analytics 4 — get from analytics.google.com → Admin → Data Streams → Measurement ID
# Format: G-XXXXXXXXXX  (leave empty to disable GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
